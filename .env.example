# API server
API_PORT=3001
CORS_ORIGIN=http://127.0.0.1:5173
API_DEBUG=true
TOTAL_CONTENT_LIVE_CACHE_TTL_MS=1800000
TOTAL_LIVE_METASEA_QUERY_TIMEOUT_MS=80000
TOTAL_LIVE_PARTNERDB_QUERY_TIMEOUT_MS=80000

# Redis cache (backend metrics cache)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=ddex-report-portal

# Metasea DB (Postgres)
METASEA_DB_HOST=127.0.0.1
METASEA_DB_PORT=5432
METASEA_DB_NAME=your_metasea_db
METASEA_DB_USER=your_metasea_user
METASEA_DB_PASSWORD=your_metasea_password
METASEA_DB_SSL=false
METASEA_DB_SSL_REJECT_UNAUTHORIZED=false

# B2B DB (MySQL 5.7.42-log)
B2B_DB_HOST=127.0.0.1
B2B_DB_PORT=3306
B2B_DB_NAME=your_b2b_db
B2B_DB_USER=your_b2b_user
B2B_DB_PASSWORD=your_b2b_password
B2B_DB_CONNECTION_LIMIT=10

# Audio partner query configuration
# Use JSON maps to configure multiple partners.
METASEA_AUDIO_PARTNER_RETAILER_IDS={"amazon":3044,"bytedance":3632,"facebook":13640,"jiosaavn":3564,"spotify":3634,"virgin":13676}
B2B_AUDIO_PARTNER_TABLES={"amazon":{"contents":"AMAZON_DDEX_BATCH_WISE_CONTENTS","push":"AMAZON_DDEX_BATCH_PUSH"},"bytedance":{"contents":"BYTEDANCE_DDEX_BATCH_WISE_CONTENTS","push":"BYTEDANCE_DDEX_BATCH_PUSH"},"facebook":{"contents":"FACEBOOK_DDEX_BATCH_WISE_CONTENTS","push":"FACEBOOK_DDEX_BATCH_PUSH"},"jiosaavn":{"contents":"JIOSAAVN_DDEX_BATCH_WISE_CONTENTS","push":"JIOSAAVN_DDEX_BATCH_PUSH"},"spotify":{"contents":"SPOTIFY_DDEX_BATCH_WISE_CONTENTS","push":"SPOTIFY_DDEX_BATCH_PUSH"},"virgin":{"contents":"VIRGIN_DDEX_BATCH_WISE_CONTENTS","push":"VIRGIN_DDEX_BATCH_PUSH"}}

# Optional explicit amazon overrides
METASEA_AMAZON_RETAILER_ID=3044
B2B_AMAZON_CONTENTS_TABLE=AMAZON_DDEX_BATCH_WISE_CONTENTS
B2B_AMAZON_PUSH_TABLE=AMAZON_DDEX_BATCH_PUSH

# Auth bootstrap (SQLite-backed local store)
# Default seeded admin is: username=Admin password=Admin
